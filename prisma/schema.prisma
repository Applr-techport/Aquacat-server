generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  provider      String    // "google" | "apple"
  displayName   String?
  gender        String?
  weight        Float
  wakeTime      String    @default("08:00")  // HH:mm
  sleepTime     String    @default("24:00")
  activityLevel String    @default("normal") // "low" | "normal" | "high"
  ageGroup      String    @default("30s") // "20s" | "30s" | "40s" | "50+"
  goalMl        Int       @default(2000)
  isPremium     Boolean   @default(false)
  mealTimes     String    @default("08:30,13:00,19:30") // CSV
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  waterLogs     WaterLog[]
  dailySummaries DailySummary[]
  purchases     Purchase[]
  achievements  Achievement[]
}

model WaterLog {
  id        String   @id @default(cuid())
  userId    String
  amount    Int      // ml
  drinkType String   @default("water") // water, coffee, tea, juice, other
  loggedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
}

model DailySummary {
  id           String   @id @default(cuid())
  userId       String
  date         String   // "2026-02-16"
  totalMl      Int      @default(0)
  goalMl       Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  type        String   // "streak_7", "streak_30", "total_100L", "first_perfect", "early_bird" etc
  unlockedAt  DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

model HealthTip {
  id      String @id @default(cuid())
  content String
  active  Boolean @default(true)
}

model Purchase {
  id            String   @id @default(cuid())
  userId        String
  productId     String   // "remove_ads"
  platform      String   // "android" | "ios"
  price         Int      // KRW
  currency      String   @default("KRW")
  transactionId String?  @unique
  status        String   @default("completed") // "completed" | "refunded"
  purchasedAt   DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([purchasedAt])
}
